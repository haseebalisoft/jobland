# Copy to .env and fill in values

# Database
DATABASE_URL=
# or: DB_HOST= DB_PORT= DB_USER= DB_PASSWORD= DB_NAME=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Groq — Hirdlogic support chat AI (required for /api/support-chat streaming)
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
