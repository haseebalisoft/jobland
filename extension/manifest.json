{
  "manifest_version": 3,
  "name": "HiredLogics Capture",
  "version": "1.0.0",
  "description": "Capture job details from job boards and submit to HiredLogics. For BDs: get your API key from the BD dashboard (Copy Capture API key).",
  "action": {
    "default_title": "HiredLogics Capture",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["content.js", "popup.html", "options.html"], "matches": ["<all_urls>"] }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
